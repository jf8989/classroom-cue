{
  "manifest_version": 3,
  "name": "Classroom Cue",
  "version": "1.0.0",
  "description": "A polished, lightweight soundboard for lively Google Meet classes.",
  "action": {
    "default_title": "Classroom Cue",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["main-world.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["tabs"],
  "host_permissions": ["https://meet.google.com/*"]
}
